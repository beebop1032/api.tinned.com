<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: DejaVu Sans, sans-serif; font-size: 12px; color: #1a1a1a; }
    h1 { font-size: 20px; color: #333; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
    th { background: #f5f5f5; }
    .total { font-weight: bold; font-size: 14px; }
  </style>
</head>
<body>
  <div style="display:flex; justify-content:space-between; margin-bottom:24px;">
    <div><strong>Tinned / BeebopCity</strong><br>Facture client</div>
    <div>Réf : {{ order.reference }}<br>Date : {{ order.createdAt|date('d/m/Y') }}</div>
  </div>
  <h1>Facture #{{ order.reference }}</h1>
  <table>
    <thead>
      <tr><th>Produit</th><th>SKU</th><th>Qté</th><th>Prix unitaire</th><th>Total</th></tr>
    </thead>
    <tbody>
      {% for line in order.lines %}
      <tr>
        <td>{{ line.variant.product.name }}</td>
        <td>{{ line.variant.sku }}</td>
        <td>{{ line.quantity }}</td>
        <td>{{ (line.variant.priceCents / 100)|number_format(2, ',', ' ') }} €</td>
        <td>{{ (line.lineTotalCents / 100)|number_format(2, ',', ' ') }} €</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr><td colspan="4">Livraison</td><td>{{ (order.shippingCents / 100)|number_format(2, ',', ' ') }} €</td></tr>
      <tr class="total"><td colspan="4">Total</td><td>{{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</td></tr>
    </tfoot>
  </table>
</body>
</html>
