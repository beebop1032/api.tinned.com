# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://app:change-me@127.0.0.1:3306/tinned?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://((localhost|127\.0\.0\.1)(:[0-9]+)?|(appbeta|api)\.tinned\.com)$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me
###< lexik/jwt-authentication-bundle ###

###> google/apiclient ###
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_CONFIG=%kernel.project_dir%/path/to/file.json
###< google/apiclient ###

APP_API_KEY=change-me
APP_PUBLIC_BASE_URL=https://appbeta.tinned.com
APP_OAUTH_DEEP_LINK_SCHEME=appbeta
DOC_USER_PASSWORD=

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM=no-reply@tinned.com
###< symfony/mailer ###

###> shipping labels ###
SHIPPING_SENDER_NAME=Tinned
SHIPPING_SENDER_STREET=
SHIPPING_SENDER_STREET_NUMBER=1
SHIPPING_SENDER_POSTAL_CODE=
SHIPPING_SENDER_CITY=
SHIPPING_SENDER_COUNTRY_CODE=BE
SHIPPING_SENDER_PHONE=
SHIPPING_SENDER_EMAIL=

DPD_API_URL=
DPD_API_USERNAME=
DPD_API_PASSWORD=

MONDIAL_RELAY_API_V2_URL=
MONDIAL_RELAY_API_V2_BRAND_ID=
MONDIAL_RELAY_API_V2_LOGIN=
MONDIAL_RELAY_API_V2_PASSWORD=

BPOST_API_URL=https://shm-rest.bpost.cloud/services/shm
BPOST_API_USERNAME=
BPOST_API_PASSWORD=
###< shipping labels ###

###> mollie ###
MOLLIE_API_KEY=test_placeholder
MOLLIE_REDIRECT_URL=http://localhost:4000/checkout/confirmation
MOLLIE_WEBHOOK_URL=https://api.tinned.com/api/payment/webhook
###< mollie ###

###> resend / subscriptions ###
# Leave RESEND_API_KEY empty in committed config; set it in .env.local.
# The mailer no-ops gracefully (no crash, no HTTP call) when the key is absent.
RESEND_API_KEY=
RESEND_FROM="Tinned <onboarding@resend.dev>"
APP_FRONT_URL=http://localhost:4001
###< resend / subscriptions ###
